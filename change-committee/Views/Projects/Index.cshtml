@model change_committee.ViewModels.Projects.ProjectsPageViewModel

<section class="page-header-row">
    <div>
        <h1>Proyectos</h1>
        <p>Vista consolidada de proyectos y volumen de solicitudes.</p>
    </div>
    <a asp-controller="ChangeRequests" asp-action="Create" class="btn-primary"><i class="bi bi-plus-circle-fill"></i> Nueva Solicitud</a>
</section>

<section class="kpi-grid two">
    <article class="kpi-card soft">
        <div class="kpi-icon sky"><i class="bi bi-kanban-fill"></i></div>
        <span>Total proyectos</span>
        <h3>@Model.TotalProjects</h3>
    </article>
    <article class="kpi-card soft">
        <div class="kpi-icon amber"><i class="bi bi-clock-fill"></i></div>
        <span>Solicitudes activas</span>
        <h3>@Model.ActiveRequests</h3>
    </article>
</section>

<section class="panel">
    <div class="table-wrap">
        <table class="table">
            <thead>
                <tr>
                    <th>Proyecto</th>
                    <th>Descripcion</th>
                    <th>Total solicitudes</th>
                    <th>Pendientes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Projects)
                {
                    <tr>
                        <td><strong>@item.Name</strong></td>
                        <td>@item.Description</td>
                        <td>@item.TotalRequests</td>
                        <td>@item.PendingRequests</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
