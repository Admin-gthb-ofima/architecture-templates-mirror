@model change_committee.ViewModels.Committee.CommitteeMemberFormViewModel

<section class="page-header-row">
    <div>
        <h1>Nuevo Integrante</h1>
        <p>Registre un nuevo miembro del comite de cambios.</p>
    </div>
</section>

<section class="panel form-panel">
    <form asp-action="Create" method="post" class="crud-form">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="field-error"></div>

        <div class="grid-two">
            <div>
                <label asp-for="Name">Nombre completo</label>
                <input asp-for="Name" />
                <span asp-validation-for="Name" class="field-error"></span>
            </div>
            <div>
                <label asp-for="Role">Cargo</label>
                <input asp-for="Role" />
                <span asp-validation-for="Role" class="field-error"></span>
            </div>
        </div>

        <div class="grid-two">
            <div>
                <label asp-for="Department">Departamento</label>
                <input asp-for="Department" />
                <span asp-validation-for="Department" class="field-error"></span>
            </div>
            <div>
                <label asp-for="Email">Correo</label>
                <input asp-for="Email" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>
        </div>

        <label class="remember-check">
            <input asp-for="IsActive" />
            Integrante activo
        </label>

        <div class="form-actions">
            <a asp-action="Index" class="btn-neutral">Cancelar</a>
            <button type="submit" class="btn-primary">Guardar</button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
